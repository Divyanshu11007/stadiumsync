# ─── Database ────────────────────────────────────────────────────────────────
# Get this from Railway MySQL service or PlanetScale
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Any long random string (min 32 chars). Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ─── App Identity ────────────────────────────────────────────────────────────
# Your app's unique ID (can be any string like "stadiumsync")
VITE_APP_ID=stadiumsync

# ─── OAuth (optional - only needed for login feature) ────────────────────────
# Leave blank to disable OAuth login. The app will still work without it.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─── Port ────────────────────────────────────────────────────────────────────
# Railway sets this automatically. Leave as 3000 for local dev.
PORT=3000
