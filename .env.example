# ============================================================
# StadiumSync — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=stadiumsync

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Authentication ───────────────────────────────────────────
# OAuth / OpenID Connect credentials
AUTH_CLIENT_ID=your_oauth_client_id
AUTH_CLIENT_SECRET=your_oauth_client_secret
AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Session secret (use a long random string in production)
SESSION_SECRET=replace_with_a_strong_random_secret

# ── Client (Vite) ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_NAME=StadiumSync
